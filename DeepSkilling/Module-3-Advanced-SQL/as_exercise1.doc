CREATE DATABASE companydb;
use companydb;

CREATE TABLE Products (
    ProductID INT,
    ProductName VARCHAR(50),
    Category VARCHAR(30),
    Price DECIMAL(10,2)
);
INSERT INTO Products VALUES
(1,'Laptop A','Electronics',80000),
(2,'Laptop B','Electronics',75000),
(3,'Laptop C','Electronics',75000),
(4,'Mobile A','Electronics',50000),

(5,'Chair A','Furniture',12000),
(6,'Chair B','Furniture',12000),
(7,'Table A','Furniture',10000),
(8,'Sofa A','Furniture',8000),

(9,'Shirt A','Clothing',2500),
(10,'Shirt B','Clothing',2000),
(11,'Jeans A','Clothing',2000),
(12,'T-Shirt A','Clothing',1500);



SELECT
    ProductName,
    Category,
    Price,
    ROW_NUMBER() OVER
    (
        PARTITION BY Category
        ORDER BY Price DESC
    ) AS RowNum
FROM Products;


SELECT
    ProductName,
    Category,
    Price,
    RANK() OVER
    (
        PARTITION BY Category
        ORDER BY Price DESC
    ) AS RankNo
FROM Products;


SELECT
    ProductName,
    Category,
    Price,
    DENSE_RANK() OVER
    (
        PARTITION BY Category
        ORDER BY Price DESC
    ) AS DenseRankNo
FROM Products;


WITH ProductRanks AS
(
    SELECT
        ProductName,
        Category,
        Price,
        ROW_NUMBER() OVER
        (
            PARTITION BY Category
            ORDER BY Price DESC
        ) AS RowNum
    FROM Products
)
SELECT *
FROM ProductRanks
WHERE RowNum <= 3;



